{
  "name": "@films-collection/api",
  "private": "true",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias",
    "start": "node dist/server.js",
    "db:migration:gen": "drizzle-kit generate",
    "db:migration:apply": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/scripts/seed-database",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --quiet --ext .ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1004.0",
    "@aws-sdk/s3-request-presigner": "^3.1004.0",
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/one-line-logger": "^2.0.2",
    "@fastify/static": "^8.2.0",
    "@films-collection/api-client": "workspace:^",
    "@films-collection/eslint-config": "workspace:^",
    "@films-collection/shared": "workspace:^",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "^6.1.0",
    "openai": "^6.33.0",
    "pg": "^8.18.0",
    "sanitize-html": "^2.16.0",
    "tsc-alias": "^1.8.16",
    "zod": "4.1.11"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.13.1",
    "@types/pg": "^8.16.0",
    "@types/sanitize-html": "^2.16.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.20.5",
    "typescript": "^5.6.2"
  },
  "author": "Andrii Kotliar",
  "repository": {
    "type": "git",
    "url": "https://github.com/andrikotliar/films-collection/tree/main/apps/api"
  }
}
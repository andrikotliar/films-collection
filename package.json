{
  "name": "films-collection",
  "private": true,
  "type": "module",
  "scripts": {
    "install:client": "cd ./client && pnpm install",
    "install:server": "cd ./server && pnpm install",
    "dev:client": "cd ./client && pnpm dev",
    "dev:server": "cd ./server && pnpm dev",
    "build:client": "cd ./client && pnpm build",
    "build:server": "cd ./server && pnpm build",
    "build": "pnpm build:server && pnpm build:client",
    "dev": "concurrently -k -n \"SERVER,CLIENT\" -c \"yellow,cyan\" \"pnpm dev:server\" \"pnpm dev:client\""
  },
  "author": "Andrii Kotliar",
  "repository": {
    "type": "git",
    "url": "https://github.com/andrikotliar/films-collection"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
  "summary": [
    {
      "title": "Season 1",
      "text": "The Locke family relocates to their ancestral home, Keyhouse, after a tragic event. They discover mystical keys that unlock supernatural powers and dark secrets hidden within the mansion. As they use the keys, they unwittingly awaken a sinister force that threatens them and the world."
    },
    {
      "title": "Season 2",
      "text": "The Locke family continues to explore the magical keys and their origins, leading to new challenges and threats. They face off against ancient enemies and strive to protect their family and the world from dark forces unleashed by the keys."
    },
    {
      "title": "Season 3",
      "text": "In this season, the Locke family must confront new and old enemies while dealing with the consequences of their actions. The fate of Keyhouse and the world hangs in the balance as they unlock more mysteries of the keys."
    }
  ],

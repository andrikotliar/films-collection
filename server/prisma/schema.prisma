generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Film {
  id              Int              @id @default(autoincrement())
  title           String
  type            TitleType        @default(FILM)
  style           TitleStyle       @default(LIVE_ACTION)
  releaseDate     DateTime         @map("release_date")
  duration        Int              @default(0)
  description     String?
  poster          String?
  trailer         String?
  budget          Int              @default(0)
  boxOffice       Int              @default(0) @map("box_office")
  rating          Int              @default(1)
  watchCount      Int              @default(2) @map("watch_count")
  chapterKey      String?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  publishStatus   PublishStatus    @default(COMPLETED)
  crew            FilmCrew[]
  cast            FilmCast[]
  genres          FilmGenre[]
  countries       FilmCountry[]
  studios         FilmStudio[]
  collections     FilmCollection[]
  awards          FilmAward[]
  chapters        FilmChapter[]
  nominations     FilmNomination[]
  seriesExtension SeriesExtension?

  @@index([title])
  @@map("films")
}

model Person {
  id          Int              @id @default(autoincrement())
  name        String
  image       String?
  filmsMember FilmCrew[]
  starredIn   FilmCast[]
  nominations FilmNomination[]

  @@map("people")
}

model FilmCrew {
  id       Int          @id @default(autoincrement())
  person   Person       @relation(fields: [personId], references: [id])
  personId Int          @map("person_id")
  film     Film         @relation(fields: [filmId], references: [id])
  filmId   Int          @map("film_id")
  position CrewPosition
  comment  String?

  @@map("film_crew")
}

model FilmCast {
  id             Int     @id @default(autoincrement())
  person         Person  @relation(fields: [personId], references: [id])
  personId       Int     @map("person_id")
  film           Film    @relation(fields: [filmId], references: [id])
  filmId         Int     @map("film_id")
  characterName  String  @map("character_name")
  characterImage String? @map("character_image")

  @@map("film_cast")
}

model Genre {
  id    Int         @id @default(autoincrement())
  title String      @unique
  films FilmGenre[]

  @@map("genres")
}

model FilmGenre {
  id      Int   @id @default(autoincrement())
  filmId  Int   @map("film_id")
  film    Film  @relation(fields: [filmId], references: [id])
  genreId Int   @map("genre_id")
  genre   Genre @relation(fields: [genreId], references: [id])

  @@unique([filmId, genreId])
  @@map("films_genres")
}

model Country {
  id    Int           @id @default(autoincrement())
  title String        @unique
  films FilmCountry[]

  @@map("countries")
}

model FilmCountry {
  id        Int     @id @default(autoincrement())
  filmId    Int     @map("film_id")
  film      Film    @relation(fields: [filmId], references: [id])
  countryId Int     @map("country_id")
  country   Country @relation(fields: [countryId], references: [id])

  @@unique([filmId, countryId])
  @@map("films_countries")
}

model Studio {
  id    Int          @id @default(autoincrement())
  title String       @unique
  films FilmStudio[]

  @@map("studios")
}

model FilmStudio {
  id       Int    @id @default(autoincrement())
  filmId   Int    @map("film_id")
  film     Film   @relation(fields: [filmId], references: [id])
  studioId Int    @map("studio_id")
  studio   Studio @relation(fields: [studioId], references: [id])

  @@unique([filmId, studioId])
  @@map("films_studios")
}

model Collection {
  id          Int                @id @default(autoincrement())
  title       String             @unique
  description String?
  category    CollectionCategory @default(GENERAL)
  films       FilmCollection[]

  @@map("collections")
}

model FilmCollection {
  id           Int        @id @default(autoincrement())
  filmId       Int        @map("film_id")
  film         Film       @relation(fields: [filmId], references: [id])
  collectionId Int        @map("collection_id")
  collection   Collection @relation(fields: [collectionId], references: [id])
  order        Int        @default(1)

  @@unique([filmId, collectionId])
  @@map("films_collections")
}

model Award {
  id          Int          @id @default(autoincrement())
  title       String       @unique
  description String?
  image       String
  nominations Nomination[]
  films       FilmAward[]

  @@map("awards")
}

model FilmAward {
  id      Int   @id @default(autoincrement())
  film    Film  @relation(fields: [filmId], references: [id])
  filmId  Int   @map("film_id")
  award   Award @relation(fields: [awardId], references: [id])
  awardId Int   @map("award_id")

  @@map("films_awards")
}

model Nomination {
  id      Int              @id @default(autoincrement())
  title   String
  award   Award            @relation(fields: [awardId], references: [id])
  awardId Int              @map("award_id")
  films   FilmNomination[]

  @@map("nominations")
}

model FilmNomination {
  id           Int        @id @default(autoincrement())
  nomination   Nomination @relation(fields: [nominationId], references: [id])
  nominationId Int        @map("nomination_id")
  film         Film       @relation(fields: [filmId], references: [id])
  filmId       Int        @map("film_id")
  actorId      Int        @map("actor_id")
  actor        Person     @relation(fields: [actorId], references: [id])
  comment      String?

  @@map("films_nominations")
}

model SeriesExtension {
  id            Int            @id @default(autoincrement())
  episodesTotal Int            @default(1) @map("episodes_total")
  seasonsTotal  Int            @default(1) @map("seasons_total")
  seasons       SeriesSeason[]
  filmId        Int            @unique @map("film_id")
  film          Film?          @relation(fields: [filmId], references: [id])

  @@map("series_extensions")
}

model SeriesSeason {
  id                Int             @id @default(autoincrement())
  number            Int
  title             String?
  description       String
  episodesCount     Int             @default(1) @map("episodes_count")
  releaseDate       DateTime        @map("release_date")
  trailer           String?
  seriesExtension   SeriesExtension @relation(fields: [seriesExtensionId], references: [id])
  seriesExtensionId Int             @map("series_extension_id")

  @@map("series_seasons")
}

model FilmChapter {
  id     Int    @id @default(autoincrement())
  key    String
  filmId Int    @map("film_id")
  film   Film   @relation(fields: [filmId], references: [id])
  order  Int

  @@unique([filmId, key])
  @@index([key])
  @@map("films_chapters")
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  password     String
  role         UserRole @default(USER)
  refreshToken String?  @map("refresh_token")

  @@map("users")
}

model PendingFilm {
  id        Int      @id @default(autoincrement())
  title     String
  priority  Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("pending_films")
}

enum TitleType {
  FILM
  SERIES

  @@map("title_type")
}

enum TitleStyle {
  LIVE_ACTION
  ANIMATION

  @@map("title_style")
}

enum PublishStatus {
  COMPLETED
  PARTIAL
  DRAFT

  @@map("publish_status")
}

enum CollectionCategory {
  GENERAL
  CINEMATIC_UNIVERSE
  TOP

  @@map("collection_category")
}

enum UserRole {
  USER
  ADMIN

  @@map("user_role")
}

enum CrewPosition {
  DIRECTOR
  WRITER
  PRODUCER
  COMPOSER
  CAMERAMAN
  CREATOR

  @@map("crew_position")
}
